NODE_ENV=development
PORT=4000
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
REQUIRE_ADMIN_APPROVAL=false
MSG91_API_KEY=
MSG91_SENDER=FOODGO
LOG_LEVEL=info
SEED_ON_BOOT=true
# CORS — browser origin(s) allowed to call this API. Comma-separate for several.
# Local dev = the Vite frontend; in prod set this to the deployed frontend URL.
FRONTEND_URL=http://localhost:5173
# DATABASE_URL=postgres://user:pass@localhost:5432/foodiego  # DB deferred — unused for now
